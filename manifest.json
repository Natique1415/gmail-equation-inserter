{
  "manifest_version": 3,
  "name": "Gmail Equation Inserter",
  "version": "2.0.0",
  "description": "Insert LaTeX equations directly into Gmail compose windows.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://latex.codecogs.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Gmail Equation Inserter"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "data.js",
        "validator.js",
        "inserter.js",
        "modal.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "https://mail.google.com/*"
      ]
    }
  ]
}